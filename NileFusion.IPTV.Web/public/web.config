<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Hand all requests to the iisnode handler which runs server.js -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Route everything through server.js — it handles /proxy and static files -->
        <rule name="NodeApp" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Disable default document so iisnode handles / -->
    <defaultDocument enabled="false" />

  </system.webServer>
</configuration>
